// Hostel Manager — схема базы данных
// База: PostgreSQL (Supabase). Подключение — в .env (DATABASE_URL / DIRECT_URL).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Пользователь системы: владелец или администратор
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("ADMIN") // OWNER | ADMIN
  createdAt DateTime @default(now())
}

// Объект — отдельный хостел
model Property {
  id                String            @id @default(cuid())
  name              String
  address           String?
  createdAt         DateTime          @default(now())
  buildings         Building[]
  residents         Resident[]
  expenses          Expense[]
  expenseCategories ExpenseCategory[]
}

// Помещение — этаж, корпус, домик (имя свободное)
model Building {
  id         String   @id @default(cuid())
  name       String
  sortOrder  Int      @default(0)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  rooms      Room[]
}

// Комната
model Room {
  id         String   @id @default(cuid())
  name       String
  sortOrder  Int      @default(0)
  buildingId String
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  beds       Bed[]
}

// Место (кровать) с тремя тарифами
model Bed {
  id           String  @id @default(cuid())
  label        String
  sortOrder    Int     @default(0)
  priceDaily   Decimal @default(0)
  priceWeekly  Decimal @default(0)
  priceMonthly Decimal @default(0)
  roomId       String
  room         Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  stays        Stay[]
}

// Жилец
model Resident {
  id         String   @id @default(cuid())
  fullName   String
  phone      String?
  note       String?
  createdAt  DateTime @default(now())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  stays      Stay[]
}

// Проживание — жилец занимает место на диапазон дат
model Stay {
  id           String    @id @default(cuid())
  bedId        String
  bed          Bed       @relation(fields: [bedId], references: [id], onDelete: Cascade)
  residentId   String
  resident     Resident  @relation(fields: [residentId], references: [id], onDelete: Cascade)
  dateFrom     DateTime
  dateTo       DateTime
  rateType     String // DAILY | WEEKLY | MONTHLY
  agreedAmount Decimal
  status       String    @default("ACTIVE") // ACTIVE | ENDED
  createdAt    DateTime  @default(now())
  payments     Payment[]

  @@index([bedId])
  @@index([status])
}

// Оплата — фиксация полученных денег по проживанию
model Payment {
  id     String   @id @default(cuid())
  stayId String
  stay   Stay     @relation(fields: [stayId], references: [id], onDelete: Cascade)
  amount Decimal
  paidAt DateTime @default(now())
  note   String?
}

// Категория затрат объекта (электричество, мусор и т.п.)
model ExpenseCategory {
  id          String    @id @default(cuid())
  name        String
  isFixed     Boolean   @default(false)
  fixedAmount Decimal?
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  expenses    Expense[]
}

// Затрата по объекту
model Expense {
  id         String           @id @default(cuid())
  propertyId String
  property   Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  categoryId String?
  category   ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  amount     Decimal
  spentOn    DateTime
  photoUrl   String?
  source     String           @default("MANUAL") // MANUAL | AI
  note       String?
  createdAt  DateTime         @default(now())

  @@index([propertyId])
}
